# Kimi / Moonshot AI — floor plan vision analysis (Tier 2)
# International endpoint: https://api.moonshot.ai/v1 (model: moonshot-v1-32k-vision-preview)
# Get a key at https://platform.moonshot.ai
MOONSHOT_API_KEY=

# OneMap.sg — used for Search, Reverse-Geocode, and Themes APIs. The basemap
# tiles also use OneMap's colored "Default" SG basemap (public, no token needed;
# the credentials below are only for the Search/Geocode APIs).
# Register at https://www.onemap.gov.sg/apidocs/register
#
# PROD: set ONEMAP_EMAIL + ONEMAP_PASSWORD — the server auto-fetches and
# caches the access token and refreshes it before it expires (~3 days).
ONEMAP_EMAIL=
ONEMAP_PASSWORD=
# DEV fallback: a manually-issued static token (POST /api/auth/post/getToken).
# Used only when ONEMAP_EMAIL/PASSWORD are not set. Expires every ~3 days.
ONEMAP_TOKEN=

# Session signing (HMAC). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# REQUIRED in production — the app throws on boot of session logic if unset
# (it will not fall back to the insecure dev value in prod).
SESSION_SECRET=

# Global rolling-24h ceiling on floor-plan (Kimi-billed) readings — a runaway-cost
# circuit breaker layered on top of the per-IP Vercel Firewall limit. Default 2000.
# MAX_DAILY_READINGS=2000

# PostHog product analytics (optional). Create a free project at eu.posthog.com,
# then paste the Project API key (phc_…, public/client key — safe to expose).
# Analytics is a no-op until this is set. Host defaults to the EU cloud.
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Agent (partner) surface kill switch. OFF in production by default for the
# consumer-only first release: the agent dashboard is unreachable (every /p path
# 404s, the partner host is not routed). Defaults ON outside production so the
# team keeps building it locally/in tests. Set true to enable on a deploy
# (e.g. staging or when the agent product launches), false to force it off.
# PARTNERS_ENABLED=true

# Agent-surface hostnames (comma-separated) the proxy routes to /p (only when
# PARTNERS_ENABLED is on). Default covers production + local dev. Override
# per-environment, e.g. staging:
#   PARTNER_HOSTS=partners.staging.fengshuiai.sg
# PARTNER_HOSTS=partners.fengshuiai.sg,partners.localhost

# Consumer hostnames (comma-separated) allowlisted for building absolute Stripe
# Checkout return URLs (reading-credit packs), so a forged Host header can't
# redirect a paying user off-site. Default covers production + local dev.
# CONSUMER_HOSTS=fengshuiai.sg,www.fengshuiai.sg,fengshuiai-nine.vercel.app,localhost

# Agent invite codes (comma-separated, high-entropy) — the onboarding gate.
# A valid code approves an applicant, so keep these SECRET and rotate as needed.
# Fails closed: if unset, no application is accepted. Generate:
#   node -e "const c=require('crypto');console.log(['propnex','era'].map(l=>l+'-'+c.randomBytes(8).toString('hex')).join(','))"
PARTNER_INVITE_CODES=

# Database — local SQLite file for dev; for prod use Turso (libsql://…) + token.
# Provision via the Vercel→Turso Marketplace integration, which injects
# TURSO_DATABASE_URL/TURSO_AUTH_TOKEN; the app reads either those or the
# DATABASE_* names below. Drizzle schema is in src/lib/db/schema.ts.
DATABASE_URL=file:./data/fengshui.db
# DATABASE_AUTH_TOKEN=   # Turso auth token (prod only)

# Twilio Verify — phone-OTP verification (the anti-fraud keystone). Twilio owns
# the code: generation, delivery, expiry, attempt limits, and SG sender. Create
# a Verify Service in the Twilio Console to get the Service SID (VA…).
# Without these, dev/test accept a fixed "000000" code (never in production).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Resend — transactional email for agent magic-link sign-in.
# Without RESEND_API_KEY, dev logs the link to the server console.
RESEND_API_KEY=
EMAIL_FROM="Fengshui AI <noreply@fengshuiai.sg>"

# Stripe — agent wallet top-ups. Agents pre-fund a balance; claiming a lead
# debits it. Use TEST-mode keys pre-launch (sk_test_…). Without STRIPE_SECRET_KEY,
# dev credits top-ups instantly (offline, mirrors the OTP dev path); production
# fails closed (no top-ups, so no claims).
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_…) — verifies Stripe events at
# /api/stripe/webhook (which credits the wallet). Get it from
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# locally, or from the Stripe Dashboard webhook endpoint in prod. Without it,
# the webhook rejects every event.
STRIPE_WEBHOOK_SECRET=

# data.gov.sg (free, HDB block data + URA Master Plan)
# Register at https://guide.data.gov.sg/developer-guide
DATA_GOV_SG_API_KEY=

# LTA DataMall (free, MRT stations + expressways)
# Register at https://datamall.lta.gov.sg/
LTA_ACCOUNT_KEY=
